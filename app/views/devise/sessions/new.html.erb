<div class="auth-page">
  <div class="auth-background">
    <div class="floating-circle circle-one"></div>
    <div class="floating-circle circle-two"></div>
    <div class="floating-circle circle-three"></div>
  </div>

  <section class="auth-card">
    <div class="auth-brand">
      <div class="auth-logo">✝</div>
      <div>
        <h1>Sheffield Church Hub</h1>
        <p>Bible reading · Prayer · Small groups</p>
      </div>
    </div>

    <div class="auth-intro">
      <span class="eyebrow">Welcome back</span>
      <h2>Sign in to continue your journey.</h2>
      <p>
        Read today’s passage, check your group tasks, and share prayer requests
        with your church community.
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email address" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "you@example.com",
              class: "auth-input" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password,
              autocomplete: "current-password",
              placeholder: "Enter your password",
              class: "auth-input" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="remember-row">
          <%= f.check_box :remember_me %>
          <span>Remember me</span>
        </label>
      <% end %>

      <%= f.submit "Sign in", class: "auth-submit" %>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </section>
</div>