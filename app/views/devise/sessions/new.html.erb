<div class="auth-page">
  <div class="auth-card">

    <div class="auth-brand">
      <div class="auth-logo">✝</div>
      <div>
        <h1>Sheffield Church Hub</h1>
        <p>성경 · 기도 · 공동체</p>
      </div>
    </div>

    <div class="auth-intro">
      <h2>로그인</h2>
      <p>오늘의 말씀과 공동체를 시작하세요</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>

      <div class="form-group">
        <%= f.label :email, "이메일" %>
        <%= f.email_field :email, class: "auth-input" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "비밀번호" %>
        <%= f.password_field :password, class: "auth-input" %>
      </div>

      <div class="remember-row">
        <%= f.check_box :remember_me %> 로그인 유지
      </div>

      <%= f.submit "로그인", class: "auth-submit" %>

    <% end %>

    <div class="auth-links">
      <%= link_to "회원가입", new_registration_path(resource_name) %>
      <%= link_to "비밀번호 찾기", new_password_path(resource_name) %>
    </div>

  </div>
</div>