<!DOCTYPE html>
<html>
  <head>
    <title>Sheffield Church Hub</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <nav class="top-nav">
        <div class="brand">
          <div class="brand-icon">✝</div>
          <div>
            <strong>Sheffield Church Hub</strong>
            <span>Bible · Prayer · Groups</span>
          </div>
        </div>

        <div class="nav-links">
          <%= link_to "Home", dashboard_path %>
          <%= link_to "Bible", bible_path %>
          <%= link_to "Groups", groups_path %>
          <%= link_to "Tasks", tasks_path %>
          <%= link_to "Profile", profile_path %>

          <% if current_user.admin? %>
            <%= link_to "Admin", "#", class: "admin-link" %>
          <% end %>

          <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "logout-btn" %>
        </div>
      </nav>
    <% end %>

    <main class="page-shell">
      <% if notice %>
        <div class="flash success"><%= notice %></div>
      <% end %>

      <% if alert %>
        <div class="flash alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>